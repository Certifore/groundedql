  {
    "name": "cte_top_customers",
    "question": "Using a CTE, find the top 5 customers by order count",
    "plan": {
      "with": [
        {
          "name": "customer_order_counts",
          "plan": {
            "dataset": "orders",
            "select": [
              {
                "expr": {
                  "col": "orders.customer_id"
                },
                "alias": "customer_id"
              },
              {
                "expr": {
                  "func": "count_distinct",
                  "args": [
                    {
                      "col": "orders.order_id"
                    }
                  ]
                },
                "alias": "order_count"
              }
            ],
            "group_by": [
              {
                "col": "orders.customer_id"
              }
            ],
            "limit": 1000,
            "offset": 0
          }
        }
      ],
      "dataset": "customer_order_counts",
      "select": [
        {
          "expr": {
            "col": "customer_order_counts.customer_id"
          },
          "alias": "customer_id"
        },
        {
          "expr": {
            "col": "customer_order_counts.order_count"
          },
          "alias": "order_count"
        }
      ],
      "order_by": [
        {
          "by": "order_count",
          "dir": "desc"
        }
      ],
      "limit": 5,
      "offset": 0
    }
  },
  {
    "name": "setop_union_customers_germany_france",
    "question": "Show customers from Germany or France",
    "plan": {
      "set_op": {
        "op": "union_all",
        "left": {
          "dataset": "customers",
          "select": [
            {
              "expr": {
                "col": "customers.customer_id"
              },
              "alias": "customer_id"
            },
            {
              "expr": {
                "col": "customers.company_name"
              },
              "alias": "company_name"
            },
            {
              "expr": {
                "col": "customers.country"
              },
              "alias": "country"
            }
          ],
          "where": {
            "cmp": {
              "left": {
                "col": "customers.country"
              },
              "op": "=",
              "right": "Germany"
            }
          },
          "limit": 100,
          "offset": 0
        },
        "right": {
          "dataset": "customers",
          "select": [
            {
              "expr": {
                "col": "customers.customer_id"
              },
              "alias": "customer_id"
            },
            {
              "expr": {
                "col": "customers.company_name"
              },
              "alias": "company_name"
            },
            {
              "expr": {
                "col": "customers.country"
              },
              "alias": "country"
            }
          ],
          "where": {
            "cmp": {
              "left": {
                "col": "customers.country"
              },
              "op": "=",
              "right": "France"
            }
          },
          "limit": 100,
          "offset": 0
        }
      }
    }
  },
  {
    "name": "case_product_price_tier",
    "question": "Categorise products as cheap, mid, or expensive by unit price",
    "plan": {
      "dataset": "products",
      "select": [
        {
          "expr": {
            "col": "products.product_name"
          },
          "alias": "product_name"
        },
        {
          "expr": {
            "col": "products.unit_price"
          },
          "alias": "unit_price"
        },
        {
          "expr": {
            "case": {
              "whens": [
                {
                  "when": {
                    "cmp": {
                      "left": {
                        "col": "products.unit_price"
                      },
                      "op": "<",
                      "right": 20
                    }
                  },
                  "then": {
                    "lit": "cheap"
                  }
                },
                {
                  "when": {
                    "cmp": {
                      "left": {
                        "col": "products.unit_price"
                      },
                      "op": "<",
                      "right": 50
                    }
                  },
                  "then": {
                    "lit": "mid"
                  }
                }
              ],
              "else": {
                "lit": "expensive"
              }
            }
          },
          "alias": "price_tier"
        }
      ],
      "order_by": [
        {
          "by": "unit_price",
          "dir": "asc"
        }
      ],
      "limit": 100,
      "offset": 0
    }
  },
